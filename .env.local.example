# Tenant identity
DOCS_TENANT_ID=quikpe
DOCS_BRAND_NAME=QuikPe
DOCS_BRAND_COMPANY=QuikPe Payments

# Access passwords (required — site is never public)
# Comma-separated. Any one of these gets a visitor in via the /login page.
# Rotate by editing this list and redeploying; bumping DOCS_AUTH_SECRET also
# invalidates every existing session cookie.
DOCS_PASSWORDS=replace-me,another-shared-password
DOCS_AUTH_SECRET=replace-me-with-32+-random-chars-eg-openssl-rand-hex-32

# API endpoints (referenced in MDX via <ApiUrl env="sandbox" />)
DOCS_API_SANDBOX_URL=https://sandbox.quikpe.live/uapi/v1/peatio
DOCS_API_PRODUCTION_URL=https://api.quikpe.live/uapi/v1/peatio
DOCS_API_VERSION=v1

# Branding (consumed by the Next app, not the OpenAPI spec)
DOCS_LOGO_URL=/logos/quikpe.svg
DOCS_PRIMARY_COLOR=#1e3a6e
DOCS_SITE_URL=https://docs.quikpe.com

# Contact / support
DOCS_SUPPORT_EMAIL=devs@quikpe.com
DOCS_SUPPORT_URL=https://quikpe.com/support
DOCS_DASHBOARD_URL=https://app.quikpe.com
