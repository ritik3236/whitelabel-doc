# --- Required (6) — build fails on any missing ---

# Brand
DOCS_BRAND_NAME=QuikPe

# Auth — both required, site is never public.
# DOCS_PASSWORDS: comma-separated; any one logs in via /login.
# DOCS_AUTH_SECRET: 32+ random hex chars (e.g. `openssl rand -hex 32`).
# Rotating the secret invalidates every active session cookie.
DOCS_PASSWORDS=replace-me,another-shared-password
DOCS_AUTH_SECRET=replace-me-with-32+-random-chars

# API base URLs — rendered by <ApiUrl env="sandbox|production" /> in MDX.
DOCS_API_SANDBOX_URL=https://sandbox.quikpe.live/uapi/v1/peatio
DOCS_API_PRODUCTION_URL=https://api.quikpe.live/uapi/v1/peatio

# Outbound link from docs back into the merchant dashboard.
DOCS_DASHBOARD_URL=https://app.quikpe.com

# --- Optional (1) — defaults to DOCS_BRAND_NAME when unset ---

# Longer brand name used by <Company /> ("QuikPe" vs "QuikPe Payments").
# Set only when you need it different from DOCS_BRAND_NAME.
# DOCS_BRAND_COMPANY=QuikPe Payments
